# CORS: 로컬은 기본값 사용, 배포 시 Vercel 도메인 추가
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Supabase (현재 미사용, 추후 Storage/Auth 연동용)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
