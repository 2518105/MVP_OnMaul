KAKAO_REST_API_KEY=카카오_개발자_콘솔의_REST_API_키
KAKAO_CLIENT_SECRET=카카오_개발자_콘솔의_클라이언트_시크릿
SECRET_KEY=랜덤_비밀키_아무_문자열

# Supabase Shared Pooler (Transaction mode, IPv4 호환, 무료)
# Supabase 대시보드 > Connect > Transaction pooler 에서 확인
DATABASE_URL=postgresql+psycopg://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:6543/postgres

# CORS: 로컬은 기본값 사용, 배포 시 Vercel 도메인 추가
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Supabase (현재 미사용, 추후 Storage/Auth 연동용)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
